{
  "expo": {
    "name": "PH Salon Manager",
    "slug": "phsalonmanager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "phsalonmanager",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.phsalonmanager.app"
    },
    "android": {
      "package": "com.phsalonmanager.app",
      "adaptiveIcon": {
        "backgroundColor": "#1A0A0F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "name": "SalonPOS",
      "shortName": "SalonPOS",
      "description": "Professional Salon Point of Sale & Management System",
      "themeColor": "#C9536E",
      "backgroundColor": "#1A0A0F",
      "display": "standalone",
      "orientation": "portrait",
      "startUrl": "/"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}